        <div class="container-order container">

            <div class="products">
                <h1 id="ava-item">Booking</h1>
                <%if(bookings){%>
                    <table>
                        <thead>
                            <th style="border: 1px solid #000;">Name</th>
                            <th style="border: 1px solid #000;">Date</th>
                            <th style="border: 1px solid #000;">Persons</th>
                            <th style="border: 1px solid #000;">Request</th>
                            <th style="border: 1px solid #000;">Function</th>
                        </thead>
                        <tbody>
                            <%bookings.forEach((v)=>{%>
                                <tr>
                                    <!-- Inside the booking table -->
                                    <td style="border: 1px solid #000;">
                                        <%=v.uname%>
                                    </td>
                                    <td style="border: 1px solid #000;">
                                        <%=v.date%>
                                    </td>
                                    <td style="border: 1px solid #000;">
                                        <%=v.people%>
                                    </td>
                                    <td style="border: 1px solid #000;">
                                        <%=v.req%>
                                    </td>
                                    <td style="border: 1px solid #000;">
                                        <!-- Add a delete button/link -->
                                        <button class="btn-primary btn"
                                            onclick="deleteBooking('<%=v._id%>')">Delete</button>
                                    </td>

                                </tr>
                                <%})%>
                        </tbody>
                    </table>
                    <%}%>
            </div>

