    <script>
        function deleteBooking(id) {
            // Send a DELETE request to the server
            fetch(`/delete/booking/${id}`, {
                method: 'DELETE',
                headers: {
                    'Content-Type': 'application/json'
                }
            })
                .then(response => {
                    if (response.ok) {
                        console.log('Booking deleted successfully');
                        // Optionally, update the UI without reloading the page
                    } else {
                        console.error('Failed to delete booking');
                    }
                })
                .catch(error => console.error('Error:', error));
        }

        function deleteUser(id) {
            // Send a DELETE request to the server
            fetch(`/delete/user/${id}`, {
                method: 'DELETE',
                headers: {
                    'Content-Type': 'application/json'
                }
            })
                .then(response => {
                    if (response.ok) {
                        console.log('User deleted successfully');
                        // Optionally, update the UI without reloading the page
                    } else {
                        console.error('Failed to delete user');
                    }
                })
                .catch(error => console.error('Error:', error));
        }


        let table = document.getElementById('showData');
        function bookingData(bookings) {
            table.innerHTML = '';
            bookings = JSON.parse(bookings);
            let thead = document.createElement('thead');
            let tbody = document.createElement('tbody');
            let tr = document.createElement('tr');
            let th1 = document.createElement('th');
            let th2 = document.createElement('th');
            let th3 = document.createElement('th');
            let th4 = document.createElement('th');
            th1.innerHTML = 'Name';
            th2.innerHTML = 'Date';
            th3.innerHTML = 'Persons';
            th4.innerHTML = 'Request';
            bookings.forEach(b => {
                let tr = document.createElement('tr');
                let td1 = document.createElement('td');
                let td2 = document.createElement('td');
                let td3 = document.createElement('td');
                let td4 = document.createElement('td');
                td1.innerHTML = b.uname;
                td2.innerHTML = b.date;
                td3.innerHTML = b.people;
                td4.innerHTML = b.req;
                tr.append(td1, td2, td3, td4);
                tbody.append(tr);
            })
            tr.append(th1, th2, th3, th4);
            thead.append(tr);
            table.append(thead, tbody);
        }
    </script>
