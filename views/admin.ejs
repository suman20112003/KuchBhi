                                    </td>
                                    <td style="border: 1px solid #000;">
                                        <!-- Add a delete button/link -->
                                        <button class="btn-primary btn add-to-cart"
                                            onclick="deleteUser('<%=v._id%>')">Delete</button>
                                    </td>

                                </tr>
                                <%})%>
